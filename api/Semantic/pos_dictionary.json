      "label": "Toast POS",
      "detection_signatures": {
        "comment": "How to recognize a Toast export from its headers. If 2+ signature columns are present, classify as Toast.",
        "signature_columns": [
          "Business Date",
          "Net Sales",
          "Gross Sales",
          "Void Amount",
          "Check Count"
        ],
        "filename_hints": [
          "toast",
